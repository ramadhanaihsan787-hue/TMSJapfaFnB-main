# Frontend Environment Configuration
# Copy this file to .env.local and fill in the actual values

# ============= API CONFIGURATION =============
# Backend API base URL
VITE_API_URL=http://localhost:8000

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# ============= AUTHENTICATION =============
# JWT token storage key in localStorage
VITE_TOKEN_KEY=auth_token

# JWT token refresh interval in milliseconds
VITE_TOKEN_REFRESH_INTERVAL=3600000

# ============= APPLICATION CONFIG =============
# Application environment: development, staging, production
VITE_ENV=development

# Application version
VITE_APP_VERSION=1.0.0

# Application name
VITE_APP_NAME=TMS Japfa FnB

# ============= THIRD-PARTY SERVICES =============
# Google Maps API Key (for mapping features)
VITE_GOOGLE_MAPS_KEY=

# TomTom API Key (for distance/routing calculations)
VITE_TOMTOM_API_KEY=

# ============= LOGGING & DEBUGGING =============
# Enable debug logging: true or false
VITE_DEBUG_MODE=true

# Log level: error, warn, info, debug, trace
VITE_LOG_LEVEL=debug

# ============= FEATURES & FEATURES TOGGLES =============
# Enable load planner 3D visualization
VITE_ENABLE_3D_PLANNER=true

# Enable POD verification features
VITE_ENABLE_POD=true

# Enable analytics dashboard
VITE_ENABLE_ANALYTICS=true

# Enable map features
VITE_ENABLE_MAP=true

# ============= UI CONFIGURATION =============
# Default theme: light, dark, auto
VITE_DEFAULT_THEME=light

# Enable animations: true or false
VITE_ENABLE_ANIMATIONS=true

# Items per page for paginated lists
VITE_ITEMS_PER_PAGE=10

# ============= SECURITY =============
# CORS allowed origins (comma-separated)
VITE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Enable HTTPS only: true or false (set to true in production)
VITE_HTTPS_ONLY=false

# ============= MONITORING & ANALYTICS (Optional) =============
# Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Google Analytics ID
VITE_GOOGLE_ANALYTICS_ID=

# ============= BUSINESS CONFIG =============
# Default delivery time window (HH:mm format)
VITE_DEFAULT_DELIVERY_START=08:00
VITE_DEFAULT_DELIVERY_END=17:00

# Maximum order weight in kg
VITE_MAX_ORDER_WEIGHT=5000

# Maximum order volume in m3
VITE_MAX_ORDER_VOLUME=50
