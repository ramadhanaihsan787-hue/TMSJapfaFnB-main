# ==========================================
# TMS JAPFA - ENVIRONMENT CONFIGURATION
# ==========================================
# 
# IMPORTANT: JANGAN COMMIT FILE .env KE GIT!
# Gunakan .env.local untuk local development
# Gunakan .env.production untuk production
#
# Template ini menunjukkan semua variable yang diperlukan
# Copy ke .env dan isi dengan nilai actual
# 

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DATABASE_URL=postgresql://japfa_user:japfa_password_change_me@localhost:5432/tms_japfa

# ==========================================
# JWT & SECURITY
# ==========================================
SECRET_KEY=your-super-secret-key-change-this-in-production-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# APPLICATION SETTINGS
# ==========================================
APP_NAME=TMS JAPFA - AI Engine
APP_VERSION=2.0.0
APP_DESCRIPTION=Transport Management System dengan CVRPTW Optimization
DEBUG=false

# ==========================================
# EXTERNAL API KEYS
# ==========================================
# Get from: https://developer.tomtom.com/
TOMTOM_API_KEY=your-tomtom-api-key-here

# ==========================================
# VRP & ROUTING CONFIGURATION
# ==========================================
# Koordinat Depo JAPFA Cikupa (default)
depo_lat=-6.2234
depo_lon=106.5123

# Jam operasional
vrp_start_time=07:00
vrp_end_time=17:00

# Drop time estimation
vrp_base_drop_time_mins=15
vrp_var_drop_time_mins=1

# Vehicle capacity buffer (jangan over-load)
vrp_capacity_buffer_percent=90

# ==========================================
# FILE UPLOAD CONFIGURATION
# ==========================================
UPLOAD_DIR=uploads
EPOD_DIR=uploads/epod
GEOMETRY_DIR=route_geometries

# ==========================================
# COST & OPERATIONS
# ==========================================
# Harga Bahan Bakar (Rupiah per liter)
cost_fuel_per_liter=12500.0

# Efisiensi kendaraan (km per liter)
cost_avg_km_per_liter=5.0

# Gaji driver per bulan (Rupiah)
cost_driver_salary=4500000.0

# Rate overtime (Rupiah per jam)
cost_overtime_rate=25000.0

# ==========================================
# FRONTEND CONFIGURATION (untuk Frontend/.env)
# ==========================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=TMS JAPFA
VITE_APP_VERSION=2.0.0

# ==========================================
# PRODUCTION OVERRIDE (untuk .env.production)
# ==========================================
# DATABASE_URL=postgresql://prod_user:prod_password@prod-db.example.com:5432/tms_japfa_prod
# SECRET_KEY=actual-production-secret-key-from-secure-vault
# DEBUG=false
# TOMTOM_API_KEY=prod-tomtom-key-from-vault
# VITE_API_URL=https://api.tms-japfa.com
